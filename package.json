{
  "name": "@hesed/recipe",
  "description": "Chains multiple CLI commands together to accomplish a task",
  "version": "0.1.0",
  "author": "Hesed",
  "bin": {
    "ai": "./bin/run.js"
  },
  "bugs": "https://github.com/hesedcasa/recipe/issues",
  "dependencies": {
    "@hesed/plugin-lib": "^0.10.0",
    "@oclif/core": "^4",
    "ansis": "^3"
  },
  "devDependencies": {
    "@eslint/compat": "^2",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^26",
    "chai": "^6",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/hesedcasa/recipe",
  "keywords": [
    "recipe",
    "oclif"
  ],
  "license": "Apache 2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "recipe",
    "dirname": "recipe",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "repository": "hesedcasa/recipe",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "find-deadcode": "ts-prune --ignore '(run|default)'",
    "format": "eslint --cache --fix --quiet . && prettier --write --cache .",
    "pre-commit": "npm run format && npm run find-deadcode"
  },
  "types": "dist/index.d.ts"
}
